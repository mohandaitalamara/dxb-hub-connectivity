%!PS-Adobe-3.0
%%BeginFeature: *PageSize Custom
<< /PageSize [5910.0 13690] >> setpagedevice
%%EndFeature
%%DocumentMedia: Plain 5910.0 13690
%%Title: Aircraft Rotations - Smoothed Shift View


/drawBox {
  % x1 y1 x2 y2 r g b drawBox
  gsave
  setrgbcolor
  newpath
  4 2 roll
  exch 2 index sub
  2 copy
  moveto
  lineto
  lineto
  lineto
  closepath
  fill
  grestore
} def

/drawText {
  % x y (text) size r g b drawText
  gsave
  setrgbcolor
  /fontsize exch def
  /Helvetica findfont fontsize scalefont setfont
  moveto
  show
  grestore
} def

/drawLine {
  % x1 y1 x2 y2 r g b width drawLine
  gsave
  setlinewidth
  setrgbcolor
  moveto
  lineto
  stroke
  grestore
} def

